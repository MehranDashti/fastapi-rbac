# Application
APP_NAME=MyApp
APP_VERSION=1.0.0
PRODUCTION=false
DEBUG=false

# Server
SERVER_LISTEN_IP=0.0.0.0
SERVER_LISTEN_PORT=8000
SERVER_WORKERS=1

# CORS
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# Database — MySQL (production)
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/mydb

# Logging
LOG_LEVEL=INFO
SYSLOG_HOST=localhost
SYSLOG_PORT=514

# JWT
SECRET_KEY=change-me-in-production-use-a-long-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Seed (optional overrides used by seed.py)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_FULLNAME=System Administrator
SEED_ADMIN_PASSWORD=Admin1234
